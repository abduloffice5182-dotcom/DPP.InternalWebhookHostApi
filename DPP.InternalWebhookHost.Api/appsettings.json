{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "System": "Warning",
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "WriteTo": [
      {
        "Name": "Http",
        "Args": {
          "requestUri": "http://log.zentropayments.com/corelog/log/fundmovementapi"
        }
      },
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level}] ({SourceContext}) {Message}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 15,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level}] ({SourceContext}) {Message}{NewLine}{Exception}"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "CoreTransaction": "Data Source=Abdullah-Device\\MSSQLSERVER01;Initial Catalog=CoreTransaction;Integrated Security=True;Connect Timeout=30;Encrypt=True;Trust Server Certificate=True;"
  },
  "CORS": {
    "AllowedOrigins": [
      "https://dev-payments.deluxe.com",
      "https://dev-payments2.deluxe.com",
      "https://q-payments.deluxe.com",
      "https://xuat-payments.deluxe.com",
      "http://localhost:8000",
      "https://payments2.deluxe.com",
      "https://payments.deluxe.com",
      "https://dev-api.deluxe.com",
      "https://q-apitran.deluxe.com",
      "https://xuat-apitran.deluxe.com",
      "https://apitran2.deluxe.com",
      "https://apitran.deluxe.com",
      "https://dev-paymentsApi.deluxe.com",
      "https://q-paymentsapi.deluxe.com",
      "https://xuat-portalapi.deluxe.com",
      "https://portalapi2.deluxe.com",
      "https://portalapi.deluxe.com"
    ]
  }
}
